DATABASE_URL=sqlite:///./app.db

# Main tutor through an OpenAI-compatible provider. Leave the key empty to use the local mock tutor.
LLM_API_KEY=
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-v4-flash
LLM_REASONING_ENABLED=false
LLM_HTTP_REFERER=http://127.0.0.1:5173
LLM_APP_TITLE=Inquiry Teaching Workbench

# Optional Dify Dataset retrieval for the main tutor. Leave empty to use mock teaching references.
DIFY_DATASET_API_URL=https://api.dify.ai/v1
DIFY_DATASET_ID=
DIFY_DATASET_API_KEY=

# Seven stage-specific Dify agents. Use "mock" for local development and "live" for real Dify calls.
DIFY_STAGE_AGENT_MODE=mock

# Optional stage agent configs. If empty, the service exposes seven mock stage agents.
# Example:
# DIFY_STAGE_AGENTS_JSON=[{"id":"stage_observation_start","stage_id":"observation_start","name":"情境探寻专家","description":"设计观察起点","api_url":"http://host/v1/chat-messages","api_key":"app-xxx","flow_names":["inquiry_7_stage"]}]
DIFY_STAGE_AGENTS_JSON=
